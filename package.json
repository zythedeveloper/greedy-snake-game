{
    "name": "greedy-snake-root",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev:frontend": "cd frontend && npm run dev -- --port 3000",
        "dev:backend": "cd backend && conda run -n greedy-snake uv run uvicorn main:app --host 0.0.0.0 --port 8000 --reload",
        "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\""
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}